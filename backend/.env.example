# ============================================
# Job Aggregator AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Database ----
DATABASE_URL=postgresql://username:password@localhost:5432/resume_optimizer

# ---- Google OAuth (Docs / Drive / Sheets) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ---- Gmail OAuth (separate account for recruiter emails) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ---- Google Docs Resume IDs ----
FRONTEND_RESUME_DOC_ID=
FULLSTACK_RESUME_DOC_ID=
BACKEND_RESUME_DOC_ID=
DEVOPS_RESUME_DOC_ID=

# ---- Google Drive & Sheets ----
DRIVE_FOLDER_ID=
TRACKING_SHEET_ID=

# ---- AI Provider (gemini or openai) ----
AI_PROVIDER=gemini
GEMINI_API_KEY=
# CHATGPT_API_KEY=

# ---- Optional: Recruiter Automation ----
SERP_API_KEY=
HUNTER_API_KEY=

# ---- Optional: Company Context ----
TAVILY_API_KEY=

# ---- Optional: Auto-Apply Bot ----
WORKDAY_EMAIL=
WORKDAY_PASSWORD=
BOT_TIMEOUT_MINUTES=30
BOT_TYPING_DELAY_MS=50
